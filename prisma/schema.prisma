generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Note: User authentication is handled by Supabase Auth, not Prisma.
// This schema only defines the Meal model for type generation.

model Meal {
  id                        String    @id @default(cuid())
  user_id                   String
  meal_name                 String?
  image_url                 String?
  calories                  Int?
  protein                   Float?
  fat                       Float?
  carbs                     Float?
  macronutrients           Json?
  micronutrients           Json?
  ingredients              String[]
  benefits                 String[]
  concerns                 String[]
  suggestions              String[]
  analysis                 Json?
  goal                     String?
  personalized_insights    String?
  insights_status          String?
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt

  @@map("meals")
}
